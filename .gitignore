# ═══════════════════════════════════════════════════════════════
#  Footy Scout — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Environment & secrets ───────────────────────────────────────
.env
.env.*
!.env.example          # keep the example file tracked

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# ── Distribution / packaging ────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# ── Unit test / coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# ── Flask / Alembic ─────────────────────────────────────────────
instance/
*.sqlite
*.db

# ── IDE / editors ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────
*.log
logs/

# ── Uploads / media (stored in Cloudinary, not Git) ─────────────
uploads/
media/

# ── Jupyter ─────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Celery ──────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Node (if you add a frontend later) ──────────────────────────
node_modules/
npm-debug.log*

# ── Docker (if added later) ─────────────────────────────────────
.dockerignore

# ── Render build cache ──────────────────────────────────────────
.render-buildpacks.json